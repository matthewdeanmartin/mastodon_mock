[MASTER]
jobs=1
py-version=3.13

[MESSAGES CONTROL]
disable=
    fixme,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-instance-attributes,
    too-many-public-methods,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-nested-blocks,
    too-many-boolean-expressions,
    too-many-ancestors,
    too-many-lines,
    too-few-public-methods,
    duplicate-code,
    import-error,
    logging-fstring-interpolation,
    not-callable,
    no-member,
    unused-import,
    import-outside-toplevel,
    wrong-import-position,
    wrong-import-order,
    ungrouped-imports,
    redefined-outer-name,
    unused-argument,
    protected-access,
    missing-docstring,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    attribute-defined-outside-init,
    invalid-name

[FORMAT]
max-line-length=120

[DESIGN]
max-args=10

[BASIC]
good-names=i,j,k,e,f,n,v,x,y,_

[REPORTS]
output-format=text
score=yes

[SIMILARITIES]
min-similarity-lines=10

[SCORING]
fail-under=9.0
