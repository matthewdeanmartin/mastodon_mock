[MASTER]
jobs=1
py-version=3.13

[MESSAGES CONTROL]
disable=
    fixme,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-instance-attributes,
    too-many-public-methods,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    too-many-nested-blocks,
    too-many-boolean-expressions,
    too-many-ancestors,
    too-many-lines,
    too-few-public-methods,
    duplicate-code,
    import-error,
    logging-fstring-interpolation,
    not-callable,
    assignment-from-no-return,
    # FastAPI route handlers keep dependency-injected and API-compat query
    # params even when a given handler does not read them.
    unused-argument,
    # Defensive request-body parsing (JSON or form) intentionally catches broadly.
    broad-exception-caught,
    # Serializers import each other lazily inside functions to break import cycles.
    import-outside-toplevel,
    # Some query/path params mirror the Mastodon API names (e.g. ``type``).
    redefined-builtin,
    # Route handler names intentionally reuse domain nouns as parameter names.
    redefined-outer-name

[FORMAT]
max-line-length=120

[DESIGN]
max-args=10

[BASIC]
good-names=i,j,k,e,f,n,v,x,y,_

[REPORTS]
output-format=text
score=yes

[SIMILARITIES]
min-similarity-lines=10

[SCORING]
fail-under=9.5
